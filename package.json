{
  "name": "node-merge-images",
  "version": "1.1.0",
  "description": "Merge multiple images into one with ImageMagick. Supports vertical/horizontal merging, custom spacing, free-form positioning, and grid layouts.",
  "type": "module",
  "main": "dist/build.common.cjs",
  "module": "dist/build.esm.js",
  "types": "types/index.d.ts",
  "files": [
    "dist",
    "screenshots",
    "types"
  ],
  "scripts": {
    "build": "rollup -c rollup.config.js",
    "prebuild": "rm -rf dist types",
    "test": "jest",
    "update-screenshots": "jest && cp __tests__/output/*.jpg screenshots/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shumatsumonobu/node-merge-images.git"
  },
  "keywords": [
    "imagemagick",
    "merge-images",
    "combine-images",
    "image-grid",
    "image-composite",
    "join-images",
    "concat-images",
    "image-layout"
  ],
  "author": "shumatsumonobu <shumatsumonobu@gmail.com> (https://x.com/shumatsumonobu)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/shumatsumonobu/node-merge-images/issues",
    "email": "shumatsumonobu@gmail.com"
  },
  "homepage": "https://github.com/shumatsumonobu/node-merge-images#readme",
  "dependencies": {
    "imagemagick": "^0.1.3"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@types/imagemagick": "^0.0.35",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.17",
    "image-size": "^1.2.1",
    "jest": "^29.7.0",
    "rollup": "^4.59.0",
    "rollup-plugin-typescript2": "^0.36.0",
    "typescript": "^5.9.3"
  }
}